# Production Environment Configuration for Angry Birdman
# Copy to /opt/angrybirdman/docker/.env.prod on the production server and fill in real values.
# chmod 600 /opt/angrybirdman/docker/.env.prod after populating.
# NEVER commit the populated .env.prod to source control.

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
POSTGRES_USER=angrybirdman_prod
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand
POSTGRES_DB=angrybirdman
KEYCLOAK_DB=keycloak

# ============================================================================
# Valkey Configuration
# ============================================================================
VALKEY_MAXMEMORY=256mb

# ============================================================================
# Keycloak Configuration
# ============================================================================
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_use_openssl_rand
KEYCLOAK_HOSTNAME=www.angrybirdman.org
KEYCLOAK_PORT=8443
KEYCLOAK_REALM=angrybirdman

# Frontend OAuth client (public client — no secret required)
KEYCLOAK_CLIENT_ID=angrybirdman-frontend

# API service account for user management (confidential client)
# Retrieve the secret from the Keycloak admin UI after first startup:
# https://www.angrybirdman.org:8443/admin → angrybirdman realm
# → Clients → angrybirdman-api-service → Credentials tab
KEYCLOAK_ADMIN_CLIENT_ID=angrybirdman-api-service
KEYCLOAK_ADMIN_CLIENT_SECRET=RETRIEVE_AFTER_FIRST_KEYCLOAK_START

# ============================================================================
# Application Configuration
# ============================================================================
APP_HOSTNAME=www.angrybirdman.org
NODE_ENV=production
